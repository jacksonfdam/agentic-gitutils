#!/usr/bin/env python3
"""
git-json-range — summarize the changes between two refs.

Output:
  {
    "base":       "main",                    # what the user typed
    "head":       "HEAD",
    "base_oid":   "abc…",
    "head_oid":   "def…",
    "merge_base": "ghi…",
    "is_symmetric": false,
    "commits":    [ …same shape as git-json-log… ],
    "files":      [ { "path": "src/foo.ts", "added": 12, "deleted": 3,
                      "binary": false, "mode": "modified" } ],
    "authors":    [ { "name": "Jane", "email": "j@x", "commits": 5 } ],
    "stats":      { "commits": 7, "files_changed": 4,
                    "insertions": 88, "deletions": 14 }
  }

Usage:
  git json-range main..HEAD           # commits reachable from HEAD, not from main
  git json-range main...HEAD          # symmetric difference
  git json-range main HEAD            # space-separated equivalent of main..HEAD
  git json-range                      # defaults to "@{u}..HEAD" if upstream exists,
                                      # otherwise HEAD~10..HEAD
"""

from __future__ import annotations

import json
import os
import re
import subprocess
import sys
from collections import defaultdict
from pathlib import Path


HERE = Path(__file__).resolve().parent


def run(cmd: list[str], check: bool = True) -> str:
    proc = subprocess.run(cmd, check=False, text=True, capture_output=True)
    if proc.returncode != 0 and check:
        sys.stderr.write(proc.stderr)
        sys.exit(proc.returncode)
    return proc.stdout


def call_json(name: str, *args: str) -> object:
    proc = subprocess.run(
        [str(HERE / name), *args],
        check=False, text=True, capture_output=True,
    )
    if proc.returncode != 0:
        sys.stderr.write(proc.stderr)
        sys.exit(proc.returncode)
    return json.loads(proc.stdout or "null")


def resolve_range(argv: list[str]) -> tuple[str, str, bool, str]:
    """Returns (base, head, symmetric, range_expr) suitable for git log."""
    if len(argv) == 0:
        # Default: upstream..HEAD if upstream exists, else HEAD~10..HEAD.
        upstream = subprocess.run(
            ["git", "rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{u}"],
            text=True, capture_output=True,
        )
        if upstream.returncode == 0 and upstream.stdout.strip():
            base = upstream.stdout.strip()
        else:
            base = "HEAD~10"
        return base, "HEAD", False, f"{base}..HEAD"

    if len(argv) == 1:
        expr = argv[0]
        m = re.match(r"^(.+?)(\.\.\.)(.+)$", expr)
        if m:
            return m.group(1), m.group(3), True, expr
        m = re.match(r"^(.+?)(\.\.)(.+)$", expr)
        if m:
            return m.group(1), m.group(3), False, expr
        # Single ref — treat as base..HEAD.
        return expr, "HEAD", False, f"{expr}..HEAD"

    if len(argv) == 2:
        base, head = argv
        return base, head, False, f"{base}..{head}"

    sys.stderr.write("usage: git json-range [<base>..<head> | <base>...<head> | <base> <head>]\n")
    sys.exit(2)


def main() -> int:
    base, head, symmetric, range_expr = resolve_range(sys.argv[1:])

    base_oid = run(["git", "rev-parse", base]).strip()
    head_oid = run(["git", "rev-parse", head]).strip()
    mb = run(["git", "merge-base", base_oid, head_oid], check=False).strip() or None

    commits = call_json("git-json-log", range_expr)

    # File-level stats via git-json-diff-stat over the same range. For symmetric
    # ranges (...), use the merge-base..head diff which is the conventional
    # interpretation of "what's in head but not base".
    diff_target = f"{mb}..{head_oid}" if (symmetric and mb) else range_expr
    raw_stats = call_json("git-json-diff-stat", diff_target)

    # Pull per-file mode info from git diff --name-status (cheap, no hunks).
    name_status = run(["git", "diff", "--name-status", "-z", diff_target])
    mode_by_path: dict[str, str] = {}
    tokens = [t for t in name_status.split("\x00") if t]
    i = 0
    while i < len(tokens):
        code = tokens[i]
        if code.startswith("R") or code.startswith("C"):
            # R<score> <old>\0<new>
            if i + 2 < len(tokens):
                mode_by_path[tokens[i + 2]] = "renamed"
                i += 3
                continue
        mode_map = {"A": "added", "D": "deleted", "M": "modified",
                    "T": "type-changed", "U": "unmerged"}
        if i + 1 < len(tokens):
            mode_by_path[tokens[i + 1]] = mode_map.get(code[:1], "modified")
            i += 2
        else:
            i += 1

    files = []
    for entry in raw_stats:
        files.append({**entry, "mode": mode_by_path.get(entry["path"], "modified")})

    # Author leaderboard.
    counts: dict[tuple[str, str], int] = defaultdict(int)
    for c in commits:
        key = (c["author"]["name"], c["author"]["email"])
        counts[key] += 1
    authors = sorted(
        ({"name": n, "email": e, "commits": v} for (n, e), v in counts.items()),
        key=lambda a: -a["commits"],
    )

    insertions = sum(f["added"] for f in files)
    deletions = sum(f["deleted"] for f in files)

    out = {
        "base": base,
        "head": head,
        "base_oid": base_oid,
        "head_oid": head_oid,
        "merge_base": mb,
        "is_symmetric": symmetric,
        "commits": commits,
        "files": files,
        "authors": authors,
        "stats": {
            "commits": len(commits),
            "files_changed": len(files),
            "insertions": insertions,
            "deletions": deletions,
        },
    }
    json.dump(out, sys.stdout, indent=2)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
