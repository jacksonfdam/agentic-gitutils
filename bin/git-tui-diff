#!/usr/bin/env python3
"""
git-tui-diff â€” side-by-side terminal diff viewer (read-only).

Same idea as `git visual-diff`, but renders ANSI in your terminal instead
of opening a browser. By default, output is piped through `less -RFX` so
you can scroll through multiple files; press `q` to quit, `/` to search,
`n` / `N` for next / previous match.

Usage:
  git tui-diff                          # working tree vs index
  git tui-diff --cached                 # staged
  git tui-diff main..feature            # branch range
  git tui-diff main -- src/foo.ts       # working file vs main
  git tui-diff v1.2.0..HEAD -- README.md

Flags:
  --no-pager       write straight to stdout (no `less`)
  --no-color       suppress ANSI escapes
  --width N        force a specific terminal width (else auto-detected)
  --context-only   show only context lines (rarely useful, but handy
                   for piping the structure into other tools)

Anything else is forwarded to `git diff` via `git-json-diff`.
"""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path
from typing import Any

HERE = Path(__file__).resolve().parent

RESET = "\x1b[0m"
DIM = "\x1b[2m"
BOLD = "\x1b[1m"
INV = "\x1b[7m"
FG_RED = "\x1b[31m"
FG_GREEN = "\x1b[32m"
FG_CYAN = "\x1b[36m"
FG_GREY = "\x1b[38;5;245m"
# Pastel backgrounds via 256-color cube; readable on both light and dark.
BG_DEL = "\x1b[48;5;52m"   # dark red
BG_ADD = "\x1b[48;5;22m"   # dark green
BG_HDR = "\x1b[48;5;236m"  # dim slate

SEPARATOR = " â”‚ "  # between the two panes


def call_json_diff(passthrough: list[str]) -> list[dict[str, Any]]:
    proc = subprocess.run(
        [str(HERE / "git-json-diff"), *passthrough],
        check=False, text=True, capture_output=True,
    )
    if proc.returncode != 0:
        sys.stderr.write(proc.stderr)
        sys.exit(proc.returncode)
    return json.loads(proc.stdout or "[]")


def pair_hunk_lines(lines: list[dict[str, Any]]) -> list[tuple[dict | None, dict | None]]:
    rows: list[tuple[dict | None, dict | None]] = []
    i = 0
    while i < len(lines):
        op = lines[i]["op"]
        if op == " ":
            rows.append((lines[i], lines[i]))
            i += 1
        elif op == "-":
            j = i
            while j < len(lines) and lines[j]["op"] == "-":
                j += 1
            k = j
            while k < len(lines) and lines[k]["op"] == "+":
                k += 1
            removed, added = lines[i:j], lines[j:k]
            for a, b in zip(removed, added):
                rows.append((a, b))
            for x in removed[len(added):]:
                rows.append((x, None))
            for x in added[len(removed):]:
                rows.append((None, x))
            i = k
        elif op == "+":
            j = i
            while j < len(lines) and lines[j]["op"] == "+":
                j += 1
            for x in lines[i:j]:
                rows.append((None, x))
            i = j
        else:
            i += 1
    return rows


def expand_tabs(text: str, width: int = 4) -> str:
    return text.expandtabs(width)


def visible_truncate(text: str, w: int) -> str:
    """Truncate to w visible columns. Assumes monospace single-cell glyphs
    (i.e., doesn't handle CJK width). Adds a `â€¦` marker when truncated."""
    text = expand_tabs(text).rstrip("\r")  # drop trailing CRs from CRLF diffs
    if len(text) <= w:
        return text.ljust(w)
    return text[: w - 1] + "â€¦"


# Each side renders to exactly `gutter_w + 2 + code_w` visible columns.
# The `2` is `space + marker` (the `+`/`-`/` ` glyph). Keep populated and
# empty sides identical width â€” otherwise the separator and right pane
# shift by one column on every row that has a None cell.
def side_width(gutter_w: int, code_w: int) -> int:
    return gutter_w + 2 + code_w


def render_side(
    side: dict | None,
    code_w: int,
    gutter_w: int,
    use_color: bool,
) -> str:
    if side is None:
        return " " * side_width(gutter_w, code_w)
    op = side["op"]
    n = side.get("n") if side.get("n") is not None else (side.get("old_no") or side.get("new_no"))
    n_str = "" if n is None else str(n)
    gutter = n_str.rjust(gutter_w)
    code = visible_truncate(side["text"], code_w)
    if not use_color:
        marker = {" ": " ", "+": "+", "-": "-"}[op]
        return f"{gutter} {marker}{code}"
    if op == "-":
        return f"{FG_RED}{gutter}{RESET} {FG_RED}-{code}{RESET}"
    if op == "+":
        return f"{FG_GREEN}{gutter}{RESET} {FG_GREEN}+{code}{RESET}"
    return f"{FG_GREY}{gutter}{RESET}  {code}"


def render_file(file: dict, total_width: int, use_color: bool) -> str:
    added = sum(1 for h in file["hunks"] for ln in h["lines"] if ln["op"] == "+")
    deleted = sum(1 for h in file["hunks"] for ln in h["lines"] if ln["op"] == "-")

    title = (
        f"{file['old_path']} â†’ {file['new_path']}"
        if file["mode"] == "renamed"
        else (file["new_path"] or file["old_path"] or "(unknown)")
    )
    parts: list[str] = []

    if use_color:
        parts.append(f"{BG_HDR}{BOLD} {title} {RESET}{BG_HDR}  {file['mode']}  "
                     f"{FG_GREEN}+{added}{RESET}{BG_HDR} / {FG_RED}-{deleted}{RESET}")
    else:
        parts.append(f"### {title}  [{file['mode']}]  +{added}/-{deleted}")

    if file["mode"] == "binary":
        parts.append("  (binary â€” not shown)")
        return "\n".join(parts) + "\n"

    # Reserve space for gutter on each side + the separator and the +/- marker.
    # gutter_w computed from max line number we'll show.
    max_n = 0
    for h in file["hunks"]:
        for ln in h["lines"]:
            for k in ("old_no", "new_no", "n"):
                v = ln.get(k)
                if isinstance(v, int) and v > max_n:
                    max_n = v
    gutter_w = max(3, len(str(max_n)))

    # Total = 2 * (gutter_w + 1 + 1 + code_w) + len(SEPARATOR)
    # where the second " 1 " is the +/- marker column.
    code_w = (total_width - len(SEPARATOR) - 2 * (gutter_w + 2)) // 2
    code_w = max(20, code_w)  # never collapse below 20 visible columns

    for h in file["hunks"]:
        hdr = h.get("header", "").rstrip()
        if use_color:
            parts.append(f"{BG_HDR}{FG_CYAN}{hdr}{RESET}")
        else:
            parts.append(hdr)
        rows = pair_hunk_lines(h["lines"])
        for L, R in rows:
            # Each side stores its own line number; for the paired-line view,
            # render_side reads from old_no/new_no via the dict directly.
            left_side = None if L is None else {**L, "n": L.get("old_no")}
            right_side = None if R is None else {**R, "n": R.get("new_no")}
            left_str = render_side(left_side,  code_w, gutter_w, use_color)
            right_str = render_side(right_side, code_w, gutter_w, use_color)
            sep = (f"{FG_GREY}{SEPARATOR}{RESET}" if use_color else SEPARATOR)
            parts.append(f"{left_str}{sep}{right_str}")

    return "\n".join(parts) + "\n"


def main() -> int:
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--no-pager",    action="store_true")
    parser.add_argument("--no-color",    action="store_true")
    parser.add_argument("--width",       type=int, default=None)
    parser.add_argument("--context-only", action="store_true")
    known, passthrough = parser.parse_known_args()

    if "-h" in passthrough or "--help" in passthrough:
        print(__doc__)
        return 0

    files = call_json_diff(passthrough)
    if not files:
        print("(no changes)", file=sys.stderr)
        return 0

    # Decide width and color.
    if known.width:
        width = known.width
    else:
        width, _ = shutil.get_terminal_size((160, 50))
    use_color = (not known.no_color) and (os.environ.get("NO_COLOR") is None)

    rendered: list[str] = []
    for f in files:
        if known.context_only:
            for h in f["hunks"]:
                h["lines"] = [ln for ln in h["lines"] if ln["op"] == " "]
        rendered.append(render_file(f, width, use_color))
        # File separator: blank + rule. Keeps `less` scroll legible.
        rendered.append("â”€" * width + "\n")

    output = "\n".join(rendered)

    # Stream through `less` if stdout is a TTY and pager is allowed.
    if known.no_pager or not sys.stdout.isatty():
        sys.stdout.write(output)
        return 0

    pager = os.environ.get("GIT_PAGER") or os.environ.get("PAGER") or "less -RFX"
    try:
        proc = subprocess.Popen(pager, shell=True, stdin=subprocess.PIPE)
    except OSError:
        sys.stdout.write(output)
        return 0
    try:
        proc.stdin.write(output.encode())
        proc.stdin.close()
        return proc.wait()
    except (BrokenPipeError, KeyboardInterrupt):
        return 0


if __name__ == "__main__":
    sys.exit(main())
