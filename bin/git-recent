#!/usr/bin/env python3
"""
git-recent — recently touched files, with touch count and last-seen metadata.

Output (JSON, default):
  [
    {
      "path": "src/foo.ts",
      "touches": 4,
      "last_commit":  "abc1234",
      "last_date":    "2026-05-26T08:30:00+02:00",
      "last_subject": "fix: handle empty input"
    }
  ]

Usage:
  git recent              # last 20 commits
  git recent 50           # last 50 commits
  git recent --since=1.week
  git recent --plain      # newline-separated unique paths, no JSON
"""

from __future__ import annotations

import json
import re
import subprocess
import sys
from collections import defaultdict
from typing import Any

OID_RE = re.compile(r"^[0-9a-f]{7,40}$")


def main() -> int:
    argv = sys.argv[1:]
    plain = False
    if "--plain" in argv:
        plain = True
        argv.remove("--plain")

    # If a bare positional integer is given, treat it as -n N.
    has_limit = any(
        a.startswith("-n") or a.startswith("--max-count")
        or a.startswith("--since") or a.startswith("--after")
        or a.startswith("--before") or a.startswith("--until")
        or (a.startswith("-") and a[1:].isdigit())
        for a in argv
    )
    if not has_limit:
        for i, a in enumerate(argv):
            if a.isdigit():
                argv[i:i + 1] = ["-n", a]
                has_limit = True
                break
    if not has_limit:
        argv = ["-n", "20", *argv]

    # We use a sentinel record separator that won't appear in normal output.
    # \x1e RS character between commit-record-and-its-files.
    sep = "\x1e"
    fmt = f"{sep}%H%n%cI%n%s"
    proc = subprocess.run(
        ["git", "log", *argv, "--name-only", f"--pretty=tformat:{fmt}"],
        check=False,
        text=True,
        capture_output=True,
    )
    if proc.returncode != 0:
        sys.stderr.write(proc.stderr)
        return proc.returncode

    by_path: dict[str, dict[str, Any]] = defaultdict(
        lambda: {"touches": 0, "last_commit": None, "last_date": "", "last_subject": ""}
    )

    # Split on the sentinel; each chunk = "<oid>\n<iso>\n<subject>\n<file>\n<file>\n..."
    for chunk in proc.stdout.split(sep):
        chunk = chunk.strip("\n")
        if not chunk:
            continue
        lines = chunk.split("\n")
        if len(lines) < 3:
            continue
        oid, date, subject, *files = lines
        if not OID_RE.match(oid):
            continue
        for path in files:
            if not path:
                continue
            entry = by_path[path]
            entry["touches"] += 1
            if date > entry["last_date"]:
                entry["last_commit"] = oid[:7]
                entry["last_date"] = date
                entry["last_subject"] = subject

    if plain:
        # Sort same way as JSON output and print unique paths.
        for path, entry in sorted(
            by_path.items(),
            key=lambda kv: (-kv[1]["touches"], kv[1]["last_date"]),
        ):
            print(path)
        return 0

    out = [
        {"path": p, **entry}
        for p, entry in sorted(
            by_path.items(),
            key=lambda kv: (-kv[1]["touches"], kv[1]["last_date"]),
        )
    ]
    json.dump(out, sys.stdout, indent=2)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
